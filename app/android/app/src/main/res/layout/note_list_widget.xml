<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/note_list_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="10dp">

    <LinearLayout
        android:id="@+id/note_list_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/note_list_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:includeFontPadding="false"
            android:text="@string/widget_list_title"
            android:textColor="#16181D"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/note_list_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="@string/widget_text_description"
            android:src="@drawable/widget_note_icon" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/note_list_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical" />

    <TextView
        android:id="@+id/note_list_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="@string/widget_empty_note"
        android:textColor="#8A93A0"
        android:textSize="13sp" />
</LinearLayout>
