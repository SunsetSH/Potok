<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFDF8"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/widget_config_title"
        android:textColor="#16181D"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/widget_config_subtitle"
        android:textColor="#5B6470"
        android:textSize="13sp" />

    <RadioGroup
        android:id="@+id/config_mode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/config_mode_latest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="@string/widget_config_mode_latest"
            android:textColor="#16181D" />

        <RadioButton
            android:id="@+id/config_mode_favorite"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/widget_config_mode_favorite"
            android:textColor="#16181D" />

        <RadioButton
            android:id="@+id/config_mode_in_work"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/widget_config_mode_in_work"
            android:textColor="#16181D" />

        <RadioButton
            android:id="@+id/config_mode_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/widget_config_mode_note"
            android:textColor="#16181D" />

        <RadioButton
            android:id="@+id/config_mode_project"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/widget_config_mode_project"
            android:textColor="#16181D" />
    </RadioGroup>

    <EditText
        android:id="@+id/config_search"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:background="@android:drawable/edit_text"
        android:hint="@string/widget_config_search_hint"
        android:inputType="text"
        android:maxLines="1"
        android:paddingHorizontal="12dp"
        android:textColor="#16181D"
        android:textColorHint="#8A93A0"
        android:visibility="gone" />

    <TextView
        android:id="@+id/config_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:textColor="#8A93A0"
        android:textSize="13sp"
        android:visibility="gone" />

    <ListView
        android:id="@+id/config_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:visibility="gone" />

    <Button
        android:id="@+id/config_apply"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:text="@string/widget_config_apply"
        android:textAllCaps="false" />
</LinearLayout>
